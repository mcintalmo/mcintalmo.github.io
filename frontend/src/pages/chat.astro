---
import Layout from '../layouts/Layout.astro';
import { loadAll } from '../lib/data';
import '../styles/globals.css';

const { config, resume } = loadAll();
---

<Layout config={config} resume={resume}>
  <div class="h-screen w-full flex flex-col items-center justify-center bg-background text-center p-8">
    <h1 class="text-2xl font-bold mb-4">Redirecting to Home...</h1>
    <p class="text-muted-foreground mb-8">The AI Chat has moved to the main page. You will be redirected shortly.</p>
    <a href="/" class="text-accent-cyan hover:underline font-medium">Click here if you are not redirected</a>
    
    <script is:inline>
      // Automatically redirect to home and open the chat if possible
      window.location.href = '/?open-chat=true';
    </script>
  </div>
</Layout>
