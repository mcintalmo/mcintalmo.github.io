---
import fs from "node:fs";
import path from "node:path";
import Layout from "../../layouts/Layout.astro";
import { Navigation } from "../../components/Navigation";
import { ThemeProvider } from "../../components/ThemeProvider";
import { VectorBackground } from "../../components/VectorBackground";
import { EvalDashboard } from "../../components/EvalDashboard";
import { loadAll } from "../../lib/data";
import "../../styles/globals.css";

const { config, resume } = loadAll();

// Load base resume.yaml directly from the resume package root
const resumeRootPath = path.resolve(process.cwd(), "../resume/resume.yaml");
let baseResumeYaml = "";
if (fs.existsSync(resumeRootPath)) {
  baseResumeYaml = fs.readFileSync(resumeRootPath, "utf-8");
} else {
  // Fallback to loaded resume config string if source file is missing
  baseResumeYaml = JSON.stringify(resume, null, 2);
}
---

<Layout config={config} resume={resume}>
  <ThemeProvider client:only="react" defaultTheme="light" storageKey="portfolio-theme">
    <Navigation client:only="react" config={config} basics={resume.basics} />
    <div class="relative z-10 min-h-screen pt-24 bg-background">
      <EvalDashboard client:only="react" baseResumeYaml={baseResumeYaml} />
    </div>
    <VectorBackground client:only="react" />
  </ThemeProvider>
</Layout>

<style is:global>
  /* Custom scrollbar styling for the YAML code editors */
  .custom-scrollbar::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 3px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.2);
  }
</style>
