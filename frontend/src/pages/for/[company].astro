---
import fs from 'node:fs';
import path from 'node:path';
import YAML from 'yaml';
import PortfolioSections from '../../components/PortfolioSections';
import Home from '../../components/Home.astro';
import Layout from '../../layouts/Layout.astro';
import { ChatAgent } from '../../components/ChatAgent';
import { loadAll } from '../../lib/data';
import '../../styles/globals.css';

export async function getStaticPaths() {
  const tailoredDir = path.join(process.cwd(), 'src/content/tailored');
  if (!fs.existsSync(tailoredDir)) {
    return [];
  }
  
  const files = fs.readdirSync(tailoredDir).filter(f => f.endsWith('.yaml'));
  
  return files.map(file => {
    const company = file.replace('.yaml', '');
    const content = fs.readFileSync(path.join(tailoredDir, file), 'utf-8');
    const tailoredResume = YAML.parse(content);
    return {
      params: { company },
      props: { tailoredResume }
    };
  });
}

const { tailoredResume } = Astro.props;
const { config } = loadAll();
---
<Layout config={config} resume={tailoredResume}>
  <div class="flex flex-col md:flex-row min-h-screen">
    <div class="flex-1 min-w-0 transition-all duration-300">
      <Home basics={tailoredResume.basics} />
      <PortfolioSections client:visible resume={tailoredResume} config={config} />
    </div>
    <ChatAgent client:only="react" />
  </div>
</Layout>
