# NVIDIA API key for LLM inference (e.g., nvapi-...)
NVIDIA_API_KEY="your-nvidia-api-key"

# LiveKit API credentials
LIVEKIT_API_KEY="your-livekit-api-key"
LIVEKIT_API_SECRET="your-livekit-api-secret"

# LiveKit connection URL
# For production: wss://livekit.alexandermcintosh.com
LIVEKIT_URL="wss://livekit.alexandermcintosh.com"

# Disable DeepEval's per-task gather timeouts. NIM latency is variable (8-50s+
# per call), so any fixed timeout causes false failures on busy clusters.
# Genuine hangs are caught by the underlying httpx client timeout.
DEEPEVAL_DISABLE_TIMEOUTS=true
